# =============================================================================
# AgentShelf — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Neon Postgres (https://neon.tech)
# Use the pooled connection URL for the main app and the direct URL for Prisma
# migrations and the Prisma CLI.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-xxx.us-east-1.aws.neon.tech/agentshelf?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx-xxx.us-east-1.aws.neon.tech/agentshelf?sslmode=require"

# -----------------------------------------------------------------------------
# NextAuth.js (https://next-auth.js.org)
# NEXTAUTH_SECRET: Generate with `openssl rand -base64 32`
# -----------------------------------------------------------------------------
NEXTAUTH_URL="https://agentshelf.io"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# -----------------------------------------------------------------------------
# Google OAuth (https://console.cloud.google.com)
# Create OAuth 2.0 credentials and add https://agentshelf.io/api/auth/callback/google
# as an authorized redirect URI.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# Stripe (https://dashboard.stripe.com)
# STRIPE_SECRET_KEY: Secret key from Stripe Dashboard (sk_live_... or sk_test_...)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: Publishable key (pk_live_... or pk_test_...)
# STRIPE_WEBHOOK_SECRET: From Stripe CLI or Webhook Dashboard (whsec_...)
# NEXT_PUBLIC_STRIPE_FEATURED_PRICE_ID: Price ID for the Featured tier listing
# NEXT_PUBLIC_STRIPE_SPOTLIGHT_PRICE_ID: Price ID for the Spotlight tier listing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_FEATURED_PRICE_ID="price_your-featured-price-id"
NEXT_PUBLIC_STRIPE_SPOTLIGHT_PRICE_ID="price_your-spotlight-price-id"

# -----------------------------------------------------------------------------
# Resend — Transactional Email (https://resend.com)
# Used for welcome emails, submission confirmations, and admin notifications.
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_your-resend-api-key"

# -----------------------------------------------------------------------------
# App URL — Public base URL for the application
# Used for generating absolute URLs in emails, OG images, and sitemaps.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://agentshelf.io"
